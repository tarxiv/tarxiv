# Token read-only for testing purposes
ATLASAPI_CONFIG=""

# TarXiv Pipeline Environemt 
TARXIV_USER="${USER}"
TARXIV_HOST="tarxiv-api"
TARXIV_PORT="9001"
TARXIV_DASHBOARD_PORT="8050"
TARXIV_CONFIG_DIR="aux"
# Tarxiv External Credentials
TARXIV_TNS_API_KEY=""
TARXIV_TNS_ID=0
TARXIV_ATLAS_TOKEN=""
# TarXiv Couchbase 
TARXIV_COUCHBASE_HOST="localhost"
TARXIV_COUCHBASE_DATA_DIR="./.data/couchbase/"
TARXIV_COUCHBASE_ADMIN_USERNAME="txv_admin"
TARXIV_COUCHBASE_ADMIN_PASSWORD="password_cbadmin"
TARXIV_COUCHBASE_PIPELINE_USERNAME="txv_pipeline"
TARXIV_COUCHBASE_PIPELINE_PASSWORD="password_cbpipe"
TARXIV_COUCHBASE_API_USERNAME="txv_api"
TARXIV_COUCHBASE_API_PASSWORD="password_cbapi"
# TarXiv Couchbase Bucket Size (in MB)
TARXIV_COUCHBASE_BUCKET_SIZE="128"
# Tarxiv ELK stack
TARXIV_ELASTIC_DATA_DIR="./.data/elastic/"
TARXIV_ELASTIC_PASSWORD="password_elastic"
TARXIV_ELASTIC_MEMORY="128"
TARXIV_LOGSTASH_MEMORY="128"
TARXIV_LOGSTASH_INTERNAL_PASSWORD="password_logstash"
TARXIV_KIBANA_SYSTEM_PASSWORD="password_kibanasys"
TARXIV_BEATS_SYSTEM_PASSWORD="password_beatssys"
# TarXiv Redis
TARXIV_REDIS_DATA_DIR="./.data/redis/"
TARXIV_REDIS_PASSWORD="password_redis"
# TarXiv Email stuff
TARXIV_IMAP_USERNAME="service@example.com"
TARXIV_IMAP_PASSWORD=""
# TARXIV Host Log Directory
TARXIV_HOST_LOG_DIR="./.data/logs/"
# TARXIV Image Source (local or ghcr.io)
TARXIV_IMAGE_SOURCE="local"
TARXIV_IMAGE_TAG="latest"

TARXIV_DASHBOARD_TOKEN="abcdef1234567890" # Change this

# Reverse proxy / LetsEncrypt 
# Here we use nip.io to provide wildcard DNS based on the host machine's global IP address.
# This allows easy testing of HTTPS locally without needing to configure DNS.
TARXIV_LETSENCRYPT_EMAIL="service@example.com"
GLOBAL_IP_DASHED="127-0-0-1"
TARXIV_API_VIRTUAL_HOST="api.${GLOBAL_IP_DASHED}.nip.io"
TARXIV_DASHBOARD_VIRTUAL_HOST="dashboard.${GLOBAL_IP_DASHED}.nip.io"
TARXIV_INTERNAL_API_URL="https://${TARXIV_HOST}:${TARXIV_PORT}"
TARXIV_EXTERNAL_API_URL="https://${TARXIV_API_VIRTUAL_HOST}"
TARXIV_DASHBOARD_URL="https://${TARXIV_DASHBOARD_VIRTUAL_HOST}"

# ORCID variables
# ORCID OAuth configuration (https://sandbox.orcid.org for testing)
ORCID_CLIENT_ID="CHANGE_ME"
ORCID_CLIENT_SECRET="CHANGE_ME"
# REDIRECT_URI needs to be public facing, secured with https (prod only), and registered on 
# the ORCID client api registration page.  
TARXIV_ORCID_REDIRECT_URI="${TARXIV_DASHBOARD_API_URL}/auth/orcid/callback"

# API Authentication & OAuth Configuration
# JWT secret shared between API and dashboard for token verification
TARXIV_JWT_SECRET="CHANGE_ME"
# Flask session secret for API (Flask requires secret_key for session handling)
TARXIV_API_SECRET_KEY="CHANGE_ME"

# POSTGRES_VARIABLES
TARXIV_POSTGRES_DB="tarxiv"
TARXIV_POSTGRES_USER="tarxiv"
TARXIV_POSTGRES_PASSWORD="password_postgres"
